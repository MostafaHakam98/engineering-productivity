# ─── status ──────────────────────────────────────────────────────────────────

cmd_status() {
    _banner
    blank
    echo -e "  ${W}Modules${NC}"
    sep
    blank

    local ss sh sb sc
    ss=$(_s_shell); sh=$(_s_hooks); sb=$(_s_browser); sc=$(_s_claude)

    printf "  %b  %-9s%b  %b%-38s%b  %s\n" "$W" "shell"   "$NC" "$D" "Bash aliases, prompt & shell manager"       "$NC" "$(_badge "$ss")"
    printf "  %b  %-9s%b  %b%-38s%b  %s\n" "$W" "hooks"   "$NC" "$D" "Git pre-commit & pre-push quality checks"   "$NC" "$(_badge "$sh")"
    printf "  %b  %-9s%b  %b%-38s%b  %s\n" "$W" "browser" "$NC" "$D" "TamperMonkey scripts for GitLab & ActiTIME" "$NC" "$(_badge "$sb")"
    printf "  %b  %-9s%b  %b%-38s%b  %s\n" "$W" "claude"  "$NC" "$D" "Global Claude Code config & skills"         "$NC" "$(_badge "$sc")"

    blank
    sep
    blank
    echo -e "  ${W}Environment${NC}"
    blank

    if command -v starship &>/dev/null; then
        ok "starship  $(starship --version 2>/dev/null | head -1)"
        [[ -f "$HOME/.config/starship.toml" ]] \
            && ok "starship config at ~/.config/starship.toml" \
            || warn "starship config missing  →  al starship install"
    else
        warn "starship not installed  →  curl -sS https://starship.rs/install.sh | sh"
    fi

    command -v atuin &>/dev/null \
        && ok "atuin  $(atuin --version 2>/dev/null | head -1)" \
        || info "atuin not installed (optional)"

    command -v fzf &>/dev/null \
        && ok "fzf  $(fzf --version 2>/dev/null | head -1)" \
        || info "fzf not installed (optional)"

    [[ -f "$HOME/.bash-preexec.sh" ]] \
        && ok "bash-preexec present" \
        || info "bash-preexec not found (optional — needed for atuin)"

    blank
    info "Run 'forge doctor' for a full dependency diagnostic."
    blank
}

# ─── doctor ──────────────────────────────────────────────────────────────────

cmd_doctor() {
    _banner
    blank
    echo -e "  ${W}Doctor — Dependency Check${NC}"
    sep
    blank
    local issues=0

    echo -e "  ${D}shell${NC}"; blank

    if ls "$HOME/.bashrc.d"/[0-9][0-9]-*.sh &>/dev/null 2>&1; then
        local count total
        count=$(ls "$HOME/.bashrc.d"/[0-9][0-9]-*.sh 2>/dev/null | wc -l | tr -d ' ')
        total=$(grep -c '^[^#[:space:]]' "$REPO_DIR/shell/aliases/load-order.conf" 2>/dev/null || echo 0)
        [[ "$count" -ge "$total" && "$total" -gt 0 ]] \
            && ok "${count} alias files in ~/.bashrc.d/" \
            || { warn "${count}/${total} alias files  →  forge install shell"; issues=$((issues+1)); }
    else
        fail "Aliases not installed  →  forge install shell"; issues=$((issues+1))
    fi

    if command -v starship &>/dev/null; then
        ok "starship $(starship --version 2>/dev/null | head -1)"
        if [[ -f "$HOME/.config/starship.toml" ]]; then
            diff -q "$REPO_DIR/shell/starship/starship.toml" "$HOME/.config/starship.toml" &>/dev/null \
                && ok "starship config in sync" \
                || warn "starship config differs  →  al starship install"
        else
            fail "starship config not installed  →  al starship install"; issues=$((issues+1))
        fi
    else
        fail "starship not installed"
        info "Install:  curl -sS https://starship.rs/install.sh | sh"
        issues=$((issues+1))
    fi

    [[ -f "$HOME/.bash-preexec.sh" ]] \
        && ok "bash-preexec present" \
        || warn "bash-preexec not found (optional — needed for atuin)"

    command -v atuin &>/dev/null && ok "atuin $(atuin --version 2>/dev/null | head -1)" || info "atuin not installed (optional)"
    command -v fzf   &>/dev/null && ok "fzf $(fzf --version 2>/dev/null | head -1)"     || info "fzf not installed (optional)"
    command -v nvm   &>/dev/null && ok "nvm present"                                     || info "nvm not installed (optional)"

    blank; echo -e "  ${D}hooks${NC}"; blank

    local hpath; hpath=$(git config --global core.hooksPath 2>/dev/null || true)
    if [[ -n "$hpath" ]]; then
        ok "core.hooksPath = $hpath"
        [[ -f "$hpath/pre-commit" ]] && ok "pre-commit present" || { fail "pre-commit missing  →  forge install hooks"; issues=$((issues+1)); }
        [[ -f "$hpath/pre-push"   ]] && ok "pre-push present"   || { fail "pre-push missing  →  forge install hooks";   issues=$((issues+1)); }
    else
        warn "Hooks not installed globally  →  forge install hooks"; issues=$((issues+1))
    fi

    blank; echo -e "  ${D}browser${NC}"; blank

    [[ -f "$REPO_DIR/.env" ]] && ok ".env configured" || { warn ".env missing  →  cp .env.example .env"; issues=$((issues+1)); }
    for f in ActiTime-AutoFill GitLab-File-Tree GitLab-Issue-MR; do
        [[ -f "$REPO_DIR/browser/scripts/${f}.js" ]] \
            && ok "${f}.js configured" \
            || warn "${f}.js not generated  →  forge install browser"
    done

    blank; echo -e "  ${D}claude${NC}"; blank

    if [[ -f "$HOME/.claude/CLAUDE.md" ]]; then
        ok "Global config at ~/.claude/"
        local skills cmds agents
        skills=$(ls "$HOME/.claude/skills/"   2>/dev/null | wc -l | tr -d ' ')
        cmds=$(ls   "$HOME/.claude/commands/" 2>/dev/null | wc -l | tr -d ' ')
        agents=$(ls "$HOME/.claude/agents/"   2>/dev/null | wc -l | tr -d ' ')
        ok "${skills} skills  ·  ${cmds} commands  ·  ${agents} agents"
    else
        fail "Claude config not installed  →  forge install claude"; issues=$((issues+1))
    fi

    blank; sep; blank

    if [[ "$issues" -eq 0 ]]; then
        echo -e "  ${G}All checks passed.${NC}"
    else
        echo -e "  ${R}${issues} issue(s) found.${NC}  Run ${W}forge install${NC} to fix them."
    fi
    blank
}

