# ─── interactive menu ────────────────────────────────────────────────────────
#
# Item format: "type:label:description:action"
#   m = module (shows status badge)
#   a = action
#   s = separator (skipped during navigation)

declare -a _ITEMS=(
    "m:shell:Bash aliases, prompt & shell manager:install_shell"
    "m:hooks:Git pre-commit & pre-push quality checks:install_hooks"
    "m:browser:TamperMonkey scripts for GitLab & ActiTIME:install_browser"
    "m:claude:Global Claude Code config & skills:install_claude"
    "s:::"
    "a:Install all modules::_install_all"
    "a:Status::cmd_status"
    "a:Doctor::cmd_doctor"
    "a:Help::cmd_help"
    "a:Quit::"
)

_next_sel() {
    # _next_sel <current_idx> <direction +1|-1>
    local idx="$1" dir="$2" n="${#_ITEMS[@]}"
    local next=$(( (idx + dir + n) % n ))
    local itype
    while true; do
        local _old_ifs="$IFS"; IFS=: read -r itype _ _ _ <<< "${_ITEMS[$next]}"; IFS="$_old_ifs"
        [[ "$itype" != "s" ]] && break
        next=$(( (next + dir + n) % n ))
    done
    echo "$next"
}

_render() {
    local sel="$1" ss="$2" sh="$3" sb="$4" sc="$5"
    local i=0

    echo -e "  ${W}Modules${NC}"
    blank

    for item in "${_ITEMS[@]}"; do
        local itype ilabel idesc iaction
        local _old_ifs="$IFS"; IFS=: read -r itype ilabel idesc iaction <<< "${item}"; IFS="$_old_ifs"

        if [[ "$itype" == "s" ]]; then
            blank; sep; blank

        elif [[ "$itype" == "m" ]]; then
            local status
            case "$ilabel" in
                shell)   status="$ss" ;;
                hooks)   status="$sh" ;;
                browser) status="$sb" ;;
                claude)  status="$sc" ;;
                *)       status="none" ;;
            esac
            local badge; badge=$(_badge "$status")

            if [[ "$i" -eq "$sel" ]]; then
                printf "  %b▶%b %b%-9s%b  %-36s  %s\n" \
                    "$B" "$NC" "$W" "$ilabel" "$NC" "$idesc" "$badge"
            else
                printf "  %b  %-9s  %-36s%b  %s\n" \
                    "$D" "$ilabel" "$idesc" "$NC" "$badge"
            fi

        elif [[ "$itype" == "a" ]]; then
            if [[ "$i" -eq "$sel" ]]; then
                printf "  %b▶ %s%b\n" "$W" "$ilabel" "$NC"
            else
                printf "  %b  %s%b\n" "$D" "$ilabel" "$NC"
            fi
        fi

        i=$((i + 1))
    done

    blank
    sep
    blank
    echo -e "  ${D}↑ ↓  navigate    Enter  select    j k  vim keys    q  quit${NC}"
    blank
}

cmd_menu() {
    local idx=0

    local ss sh sb sc
    ss=$(_s_shell); sh=$(_s_hooks); sb=$(_s_browser); sc=$(_s_claude)

    _cursor_hide
    trap '_cursor_show' EXIT INT TERM

    while true; do
        clear
        _banner
        blank
        _render "$idx" "$ss" "$sh" "$sb" "$sc"

        local key; key=$(_read_key)

        case "$key" in
            $'\x1b[A'|k|K)        idx=$(_next_sel "$idx" -1) ;;
            $'\x1b[B'|j|J)        idx=$(_next_sel "$idx"  1) ;;
            $'\x1b[H'|$'\x1b[1~') idx=0 ;;
            $'\x1b[F'|$'\x1b[4~') idx=$(( ${#_ITEMS[@]} - 1 )) ;;

            $'\n'|$'\r'|'')
                local itype iaction
                local _old_ifs="$IFS"; IFS=: read -r itype _ _ iaction <<< "${_ITEMS[$idx]}"; IFS="$_old_ifs"

                # Quit item has empty action
                [[ "$itype" == "a" && -z "$iaction" ]] && break

                _cursor_show
                clear
                "$iaction"
                _pause
                ss=$(_s_shell); sh=$(_s_hooks); sb=$(_s_browser); sc=$(_s_claude)
                _cursor_hide
                ;;

            q|Q) break ;;
        esac
    done

    _cursor_show
    blank
}

# ─── dispatch ────────────────────────────────────────────────────────────────

case "${1:-}" in
    ""|menu) cmd_menu ;;

    install)
        case "${2:-}" in
            ""|all)  _install_all ;;
            shell)   install_shell ;;
            hooks)   install_hooks ;;
            browser) install_browser ;;
            claude)  install_claude ;;
            *)
                fail "Unknown module: $2"
                blank
                info "Modules: shell  hooks  browser  claude"
                exit 1
                ;;
        esac
        ;;

    status)               cmd_status ;;
    doctor)               cmd_doctor ;;
    help|--help|-h)       cmd_help ;;
    version|--version|-v) echo "forge v${VERSION}"; exit 0 ;;

    *)
        fail "Unknown command: $1"
        blank
        info "Run 'forge help' to see all available commands."
        blank
        exit 1
        ;;
esac
