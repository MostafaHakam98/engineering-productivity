# forge — Engineering Productivity CLI
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION="1.0.0"

# ─── colors ──────────────────────────────────────────────────────────────────
B='\033[0;34m'   G='\033[0;32m'   Y='\033[1;33m'   R='\033[0;31m'
C='\033[0;36m'   W='\033[1;37m'   D='\033[2m'       NC='\033[0m'

# ─── primitives ──────────────────────────────────────────────────────────────
ok()    { echo -e "  ${G}✓${NC}  $*"; }
warn()  { echo -e "  ${Y}!${NC}  $*"; }
fail()  { echo -e "  ${R}✗${NC}  $*"; }
info()  { echo -e "  ${D}·${NC}  $*"; }
step()  { echo -e "\n  ${C}▸${NC}  $*"; }
blank() { echo ""; }
sep()   { echo -e "  ${D}$(printf '─%.0s' {1..54})${NC}"; }

_pause() { blank; printf "  Press Enter to continue..."; read -r _; }

_confirm() {
    blank
    printf "  %b%s%b  [y/N]  " "$Y" "${1:-Continue?}" "$NC"
    read -r _ans
    [[ "$_ans" =~ ^[Yy]$ ]]
}

_banner() {
    blank
    echo -e "  ${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "    ${W}forge${NC}  ${D}—${NC}  Engineering Productivity  ${D}v${VERSION}${NC}"
    echo -e "    ${D}${REPO_DIR}${NC}"
    echo -e "  ${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ─── tty helpers ─────────────────────────────────────────────────────────────
_cursor_hide() { printf '\033[?25l'; }
_cursor_show() { printf '\033[?25h'; }

# ─── inline option picker ─────────────────────────────────────────────────────
# Usage: _pick "Option one" "Option two" ...
# Result in $_PICK_IDX (0-based index of selection)

_pick_draw() {
    local sel="$1"; shift
    local i=0
    for opt in "$@"; do
        if [[ "$i" -eq "$sel" ]]; then
            printf "\r  %b▶  %s%b\033[K\n" "$W" "$opt" "$NC"
        else
            printf "\r  %b   %s%b\033[K\n" "$D" "$opt" "$NC"
        fi
        i=$((i+1))
    done
    printf "\r  %b↑ ↓  navigate    Enter  select%b\033[K\n" "$D" "$NC"
}

_pick() {
    local -a _opts=("$@")
    local _n="${#_opts[@]}" _idx=0
    _pick_draw "$_idx" "${_opts[@]}"
    _cursor_hide
    while true; do
        local _key; _key=$(_read_key)
        case "$_key" in
            $'\x1b[A'|k|K) _idx=$(( (_idx - 1 + _n) % _n )) ;;
            $'\x1b[B'|j|J) _idx=$(( (_idx + 1) % _n ))       ;;
            $'\n'|$'\r'|'') break ;;
        esac
        printf '\033[%dA' $(( _n + 1 ))
        _pick_draw "$_idx" "${_opts[@]}"
    done
    _cursor_show
    _PICK_IDX="$_idx"
}

_read_key() {
    local key seq
    IFS= read -r -s -n1 key 2>/dev/null || true
    if [[ "$key" == $'\x1b' ]]; then
        IFS= read -r -s -n2 -t0.1 seq 2>/dev/null || true
        key="${key}${seq}"
    fi
    printf '%s' "$key"
}

# ─── status checks ───────────────────────────────────────────────────────────
_s_shell() {
    if ls "$HOME/.bashrc.d"/[0-9][0-9]-*.sh &>/dev/null 2>&1; then
        local installed total
        installed=$(ls "$HOME/.bashrc.d"/[0-9][0-9]-*.sh 2>/dev/null | wc -l | tr -d ' ')
        total=$(grep -c '^[^#[:space:]]' "$REPO_DIR/shell/aliases/load-order.conf" 2>/dev/null || echo 0)
        [[ "$total" -gt 0 && "$installed" -ge "$total" ]] && echo "ok" || echo "warn"
    else
        echo "none"
    fi
}

_s_hooks() {
    local hpath
    hpath=$(git config --global core.hooksPath 2>/dev/null || true)
    [[ -n "$hpath" && -f "$hpath/pre-commit" ]] && echo "ok" || echo "none"
}

_s_browser() {
    local n=0
    for f in ActiTime-AutoFill GitLab-File-Tree GitLab-Issue-MR; do
        [[ -f "$REPO_DIR/browser/scripts/${f}.js" ]] && n=$((n + 1))
    done
    if   [[ "$n" -eq 3 ]]; then echo "ok"
    elif [[ "$n" -gt 0 ]]; then echo "warn"
    else echo "none"; fi
}

_s_claude() {
    [[ -f "$HOME/.claude/CLAUDE.md" ]] && echo "ok" || echo "none"
}

_badge() {
    case "$1" in
        ok)   printf '%b✓  installed%b'  "$G" "$NC" ;;
        warn) printf '%b!  partial%b'    "$Y" "$NC" ;;
        none) printf '%b○  not set up%b' "$D" "$NC" ;;
    esac
}

# ─── module installers ───────────────────────────────────────────────────────

install_shell() {
    blank
    echo -e "  ${W}Shell Environment${NC}"
    sep
    blank
    echo -e "  Installs modular bash aliases and the starship prompt config."
    blank
    echo -e "  ${D}Installation method:${NC}"
    blank
    _pick \
        "copy     Copy files to ~/.bashrc.d/        — stable, re-run install to update" \
        "symlink  Symlink files to this repo        — auto-updates on git pull" \
        "direct   Source repo from ~/.bashrc        — instant changes, no file copying"
    blank
    local method
    case "$_PICK_IDX" in
        1) method="symlink" ;;
        2) method="direct"  ;;
        *) method="copy"    ;;
    esac
    blank
    if ! command -v starship &>/dev/null; then
        warn "starship not installed — prompt config will be skipped"
        info "Install after:  curl -sS https://starship.rs/install.sh | sh"
        blank
    fi

    step "Installing aliases  (method: ${method})"
    blank
    bash "$REPO_DIR/shell/aliases/al" install "$method"
    blank
    echo -e "  ${W}What's next:${NC}"
    info "source ~/.bashrc          apply changes in this terminal"
    info "al status                 verify load order and installed files"
    info "al doctor                 check for missing dependencies"
}

install_hooks() {
    blank
    echo -e "  ${W}Git Hooks${NC}"
    sep
    blank
    echo -e "  Installs ${G}pre-commit${NC} and ${G}pre-push${NC} hooks that check for:"
    blank
    info "Unresolved task markers left in committed code"
    info "Debug print statements (console.log, print, pdb, etc.)"
    info "Secrets and credentials accidentally staged"
    blank
    echo -e "  ${D}Where should hooks be installed?${NC}"
    blank
    _pick \
        "global   Apply to all git repositories on this machine  (recommended)" \
        "path     A specific repository you specify"
    blank

    case "$_PICK_IDX" in
        1)
            printf "  Repository path: "
            read -r _repo_path
            blank
            if [[ -d "${_repo_path}/.git" ]]; then
                step "Installing hooks in ${_repo_path}"
                bash "$REPO_DIR/git/hooks/setup.sh" "${_repo_path}"
            else
                fail "Not a git repository: ${_repo_path}"
                return 1
            fi
            ;;
        *)
            step "Installing hooks globally"
            blank
            bash "$REPO_DIR/git/hooks/install-global.sh"
            blank
            echo -e "  ${W}What's next:${NC}"
            info "Hooks will run automatically on every commit and push"
            info "hooks-install-global      re-sync hooks from repo at any time"
            info "To bypass (use sparingly):  git commit --no-verify"
            ;;
    esac
}

install_browser() {
