#!/usr/bin/env bash
# al — shell environment CLI
# Run with no args for the interactive menu.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
TARGET_DIR="$HOME/.bashrc.d"
BASHRC="$HOME/.bashrc"
CONF="$SCRIPT_DIR/load-order.conf"
STARSHIP_SRC="$REPO_DIR/shell/starship/starship.toml"
STARSHIP_DST="$HOME/.config/starship.toml"

B='\033[0;34m'; G='\033[0;32m'; Y='\033[1;33m'; R='\033[0;31m'; D='\033[2m'; NC='\033[0m'

[[ -f "$CONF" ]] || { echo "al: load-order.conf not found at $CONF" >&2; exit 1; }

# ─── helpers ──────────────────────────────────────────────────────────────────

header() { echo -e "\n${B}$1${NC}"; }
ok()     { echo -e "  ${G}✓${NC}  $1"; }
warn()   { echo -e "  ${Y}!${NC}  $1"; }
fail()   { echo -e "  ${R}✗${NC}  $1"; }
info()   { echo -e "  ${D}·${NC}  $1"; }
_pause() { echo ""; printf "Press Enter to continue..."; read -r _p; }

_load_order() {
    while IFS=: read -r num cat file; do
        [[ "$num" =~ ^[[:space:]]*# || -z "${num// }" ]] && continue
        printf '%s:%s:%s\n' "$num" "$cat" "$file"
    done < "$CONF"
}

_aliases_method() {
    local our_file="$TARGET_DIR/00-core.sh"
    local loader="$SCRIPT_DIR/loader.sh"
    if   grep -qF "$loader"   "$BASHRC" 2>/dev/null; then echo "direct"
    elif [[ -L "$our_file" ]];                        then echo "symlink"
    elif [[ -f "$our_file" ]];                        then echo "copy"
    else                                                   echo "none"
    fi
}

_aliases_count() {
    local n=0
    while IFS=: read -r num _ file; do
        [[ -f "$TARGET_DIR/${num}-${file}" || -L "$TARGET_DIR/${num}-${file}" ]] && n=$((n+1))
    done < <(_load_order)
    echo "$n"
}

_aliases_total() {
    local n=0
    while IFS= read -r _; do n=$((n+1)); done < <(_load_order)
    echo "$n"
}

# ─── usage ────────────────────────────────────────────────────────────────────

usage() {
    echo -e "${B}al${NC} — shell environment CLI"
    echo ""
    echo -e "  ${G}al${NC}                                  Interactive menu (default)"
    echo -e "  ${G}al install${NC} [copy|symlink|direct]   Install full environment"
    echo -e "  ${G}al status${NC}                          Show environment status"
    echo -e "  ${G}al doctor${NC}                          Diagnose issues"
    echo -e "  ${G}al list${NC} [category]                 List aliases by category"
    echo -e "  ${G}al reload${NC}                          Print reload instructions"
    echo -e "  ${G}al starship${NC} <install|diff|status>  Manage starship config"
    echo ""
    echo -e "  ${D}Categories: core  navigation  tools  ai  git  docker  prompt  optional${NC}"
}

# ─── interactive menu ─────────────────────────────────────────────────────────

_menu_install() {
    while true; do
        clear
        echo -e "${B}Install method${NC}"
        echo -e "${D}──────────────${NC}"
        echo ""
        echo "  1  Copy       — stable, files copied to ~/.bashrc.d/"
        echo "  2  Symlink    — auto-updates when repo changes"
        echo "  3  Direct     — sources repo directly, instant updates"
        echo ""
        echo "  b  Back"
        echo ""
        printf "> "; read -r choice
        case "$choice" in
            1) echo ""; cmd_install copy;    _pause; return ;;
            2) echo ""; cmd_install symlink; _pause; return ;;
            3) echo ""; cmd_install direct;  _pause; return ;;
            b|B) return ;;
            *) ;;
        esac
    done
}

_menu_list() {
    local cats=(all core navigation tools ai git docker prompt optional)
    while true; do
        clear
        echo -e "${B}List aliases${NC}"
        echo -e "${D}────────────${NC}"
        echo ""
        local i=1
        for cat in "${cats[@]}"; do
            printf "  %s  %s\n" "$i" "$cat"
            i=$((i+1))
        done
        echo ""
        echo "  b  Back"
        echo ""
        printf "> "; read -r choice
        case "$choice" in
            1) echo ""; cmd_list "";          _pause ;;
            2) echo ""; cmd_list core;        _pause ;;
            3) echo ""; cmd_list navigation;  _pause ;;
            4) echo ""; cmd_list tools;       _pause ;;
            5) echo ""; cmd_list ai;          _pause ;;
            6) echo ""; cmd_list git;         _pause ;;
            7) echo ""; cmd_list docker;      _pause ;;
            8) echo ""; cmd_list prompt;      _pause ;;
            9) echo ""; cmd_list optional;    _pause ;;
            b|B) return ;;
            *) ;;
        esac
    done
}

_menu_starship() {
    while true; do
        clear
        echo -e "${B}Starship config${NC}"
        echo -e "${D}───────────────${NC}"
        echo ""
        echo "  1  Install config from repo"
        echo "  2  Show diff (repo vs installed)"
        echo "  3  Status"
        echo ""
        echo "  b  Back"
        echo ""
        printf "> "; read -r choice
        case "$choice" in
            1) echo ""; cmd_starship install; _pause ;;
            2) echo ""; cmd_starship diff;    _pause ;;
            3) echo ""; cmd_starship status;  _pause ;;
            b|B) return ;;
            *) ;;
        esac
    done
}

cmd_menu() {
    while true; do
        clear
        echo -e "${B}al — shell environment manager${NC}"
        echo -e "${D}───────────────────────────────${NC}"
        echo ""
        echo "  1  Install environment"
        echo "  2  Status"
        echo "  3  Doctor"
        echo "  4  List aliases"
        echo "  5  Starship config"
        echo "  6  Reload instructions"
        echo ""
        echo "  h  Help"
        echo "  q  Quit"
        echo ""
        printf "> "; read -r choice
        case "$choice" in
            1) _menu_install ;;
            2) clear; cmd_status;  _pause ;;
            3) clear; cmd_doctor;  _pause ;;
            4) _menu_list ;;
            5) _menu_starship ;;
            6) clear; cmd_reload;  _pause ;;
            h|H) clear; usage;     _pause ;;
            q|Q) echo ""; break ;;
            *) ;;
        esac
    done
}

# ─── list ─────────────────────────────────────────────────────────────────────

cmd_list() {
    local filter="${1:-}"
    local categories=(core navigation tools ai git docker prompt optional)

    for cat in "${categories[@]}"; do
        [[ -n "$filter" && "$filter" != "$cat" ]] && continue
        local dir="$SCRIPT_DIR/$cat"
        [[ -d "$dir" ]] || continue
        echo -e "${B}── $cat${NC}"
        for f in "$dir"/*.sh; do
            [[ -f "$f" ]] || continue
            grep -E '^alias [a-zA-Z]|^[a-zA-Z_][a-zA-Z0-9_-]*\(\)' "$f" \
                | sed "s/^alias //; s/=.*//" \
                | sed "s/().*//" \
                | sort \
                | awk '{printf "   %-22s\n", $0}'
        done
        echo ""
    done
}

# ─── status ───────────────────────────────────────────────────────────────────

cmd_status() {
    echo -e "${B}Environment status${NC}"

    header "Aliases"
    local method; method=$(_aliases_method)
    local count;  count=$(_aliases_count)
    local total;  total=$(_aliases_total)

    if [[ "$method" == "none" ]]; then
        fail "Not installed — run: al install"
    else
        ok "Method: $method"
        if [[ "$count" -eq "$total" ]]; then
            ok "Files: $count/$total in ~/.bashrc.d/"
        else
            warn "Files: $count/$total in ~/.bashrc.d/ (run: al install to fix)"
        fi
    fi

    header "Starship"
    if ! command -v starship &>/dev/null; then
        fail "starship not found in PATH"
    else
        ok "Binary: $(starship --version | head -1)"
        if [[ ! -f "$STARSHIP_DST" ]]; then
            fail "Config not installed — run: al starship install"
        elif diff -q "$STARSHIP_SRC" "$STARSHIP_DST" &>/dev/null; then
            ok "Config: in sync with repo"
        else
            warn "Config: differs from repo — run: al starship diff"
        fi
    fi

    header ".bashrc"
    local bp_pos atuin_pos star_pos
    bp_pos=$(grep -n "bash-preexec\|bash_preexec" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)
    atuin_pos=$(grep -n "atuin init bash" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)
    star_pos=$(grep -n "starship init bash" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)

    if [[ -n "$bp_pos" ]];    then ok "bash-preexec sourced (line $bp_pos)"; else warn "bash-preexec not found"; fi
    if [[ -n "$atuin_pos" ]]; then ok "atuin init found (line $atuin_pos)";  else info "atuin init not found"; fi
    if [[ -n "$star_pos" ]];  then ok "starship init found (line $star_pos)"; else fail "starship init not found — prompt won't load"; fi

    if [[ -n "$bp_pos" && -n "$atuin_pos" && -n "$star_pos" ]]; then
        if [[ "$bp_pos" -lt "$atuin_pos" && "$bp_pos" -lt "$star_pos" ]]; then
            ok "Load order correct (bash-preexec → atuin → starship)"
        else
            fail "Load order wrong — bash-preexec must come before atuin and starship"
        fi
    fi

    echo ""
}

# ─── doctor ───────────────────────────────────────────────────────────────────

cmd_doctor() {
    local issues=0
    echo -e "${B}Doctor${NC}"
    echo ""

    if [[ -f "$HOME/.bash-preexec.sh" ]]; then
        ok "~/.bash-preexec.sh exists"
    else
        fail "~/.bash-preexec.sh missing — atuin history won't track"
        info "Install: curl https://raw.githubusercontent.com/rcaloras/bash-preexec/master/bash-preexec.sh -o ~/.bash-preexec.sh"
        issues=$((issues+1))
    fi

    if command -v starship &>/dev/null; then
        ok "starship binary found"
    else
        fail "starship not installed"
        info "Install: curl -sS https://starship.rs/install.sh | sh"
        issues=$((issues+1))
    fi

    if [[ -f "$STARSHIP_DST" ]]; then
        ok "starship config exists"
        if diff -q "$STARSHIP_SRC" "$STARSHIP_DST" &>/dev/null; then
            ok "starship config matches repo"
        else
            warn "starship config differs from repo — run: al starship diff"
        fi
    else
        fail "starship config missing — run: al starship install"
        issues=$((issues+1))
    fi

    if command -v atuin &>/dev/null; then ok "atuin binary found"; else warn "atuin not found (optional)"; fi

    local count; count=$(_aliases_count)
    local total; total=$(_aliases_total)
    if [[ "$count" -eq "$total" ]]; then
        ok "All $total alias files installed"
    elif [[ "$count" -gt 0 ]]; then
        warn "$count/$total alias files installed — run: al install"
        issues=$((issues+1))
    else
        fail "Aliases not installed — run: al install"
        issues=$((issues+1))
    fi

    local bp atuin_line star
    bp=$(grep -n "bash-preexec\|bash_preexec" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)
    atuin_line=$(grep -n "atuin init bash" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)
    star=$(grep -n "starship init bash" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)

    if [[ -n "$bp" && -n "$atuin_line" && -n "$star" ]]; then
        if [[ "$bp" -lt "$atuin_line" && "$bp" -lt "$star" ]]; then
            ok ".bashrc load order correct"
        else
            fail ".bashrc load order wrong — bash-preexec must be before atuin + starship"
            issues=$((issues+1))
        fi
    elif [[ -n "$atuin_line" || -n "$star" ]]; then
        warn "bash-preexec not in .bashrc but atuin/starship are — run: al install"
        issues=$((issues+1))
    fi

    echo ""
    if [[ "$issues" -eq 0 ]]; then echo -e "  ${G}All checks passed.${NC}"; else echo -e "  ${R}$issues issue(s) found.${NC}"; fi
    echo ""
}

# ─── install ──────────────────────────────────────────────────────────────────

cmd_install() {
    local method="${1:-copy}"
    echo -e "${B}Installing environment${NC} (method: $method)"
    echo ""

    header "Aliases"
    bash "$SCRIPT_DIR/setup.sh" "$method"

    header "Starship config"
    _starship_install

    header ".bashrc"
    _bashrc_patch

    echo ""
    echo -e "${G}Done.${NC} Run: ${Y}source ~/.bashrc${NC}  (or open a new terminal)"
}

# ─── starship ─────────────────────────────────────────────────────────────────

cmd_starship() {
    local sub="${1:-status}"
    case "$sub" in
        install) _starship_install ;;
        diff)    _starship_diff ;;
        status)
            header "Starship"
            if ! command -v starship &>/dev/null; then
                fail "starship not in PATH"
            else
                ok "$(starship --version | head -1)"
                if [[ ! -f "$STARSHIP_DST" ]]; then
                    fail "Config not installed — run: al starship install"
                elif diff -q "$STARSHIP_SRC" "$STARSHIP_DST" &>/dev/null; then
                    ok "Config in sync with repo"
                else
                    warn "Config differs from repo — run: al starship diff"
                fi
            fi
            echo ""
            ;;
        *) echo -e "${R}Unknown: $sub${NC}"; echo "Usage: al starship <install|diff|status>"; exit 1 ;;
    esac
}

_starship_install() {
    if [[ ! -f "$STARSHIP_SRC" ]]; then fail "Repo config not found at $STARSHIP_SRC"; return 1; fi
    mkdir -p "$(dirname "$STARSHIP_DST")"
    if [[ -f "$STARSHIP_DST" ]]; then
        if diff -q "$STARSHIP_SRC" "$STARSHIP_DST" &>/dev/null; then ok "Starship config already up to date"; return; fi
        local bak="${STARSHIP_DST}.bak.$(date +%Y%m%d%H%M%S)"
        cp "$STARSHIP_DST" "$bak"
        warn "Backed up existing config → $bak"
    fi
    cp "$STARSHIP_SRC" "$STARSHIP_DST"
    ok "Installed $STARSHIP_DST"
}

_starship_diff() {
    if [[ ! -f "$STARSHIP_DST" ]]; then fail "~/.config/starship.toml not found — run: al starship install"; return 1; fi
    echo -e "${B}Diff: repo vs installed${NC}"
    echo -e "  ${D}--- repo: $STARSHIP_SRC${NC}"
    echo -e "  ${D}+++ live: $STARSHIP_DST${NC}"
    echo ""
    diff --color=always "$STARSHIP_SRC" "$STARSHIP_DST" || true
}

# ─── .bashrc patching ─────────────────────────────────────────────────────────

_bashrc_patch() {
    local snippet='[[ -f ~/.bash-preexec.sh ]] && source ~/.bash-preexec.sh'
    if grep -qF "bash-preexec" "$BASHRC" 2>/dev/null; then ok "bash-preexec already in ~/.bashrc"; return; fi

    local atuin_line star_line insert_at
    atuin_line=$(grep -n "atuin init bash"   "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)
    star_line=$(grep -n  "starship init bash" "$BASHRC" 2>/dev/null | head -1 | cut -d: -f1 || true)

    local bak="${BASHRC}.bak.$(date +%Y%m%d%H%M%S)"
    cp "$BASHRC" "$bak"
    warn "Backed up ~/.bashrc → $bak"

    if [[ -n "$atuin_line" || -n "$star_line" ]]; then
        insert_at="${atuin_line:-$star_line}"
        [[ -n "$atuin_line" && -n "$star_line" && "$star_line" -lt "$atuin_line" ]] && insert_at="$star_line"
        sed -i "${insert_at}i\\
# bash-preexec: must load before atuin and starship\\
${snippet}\\
" "$BASHRC"
        ok "Injected bash-preexec before line $insert_at"
    else
        printf '\n# bash-preexec: must load before atuin and starship\n%s\n' "$snippet" >> "$BASHRC"
        ok "Appended bash-preexec to ~/.bashrc"
    fi
}

# ─── reload ───────────────────────────────────────────────────────────────────

cmd_reload() {
    echo ""
    echo -e "${Y}Shell reload must be run in your terminal:${NC}"
    echo ""
    echo -e "  ${G}source ~/.bashrc${NC}                     # copy or symlink mode"
    echo -e "  ${G}source $SCRIPT_DIR/loader.sh${NC}  # direct mode"
    echo ""
}

# ─── dispatch ─────────────────────────────────────────────────────────────────

case "${1:-}" in
    "")              cmd_menu ;;
    menu)            cmd_menu ;;
    install)         cmd_install "${2:-copy}" ;;
    status)          cmd_status ;;
    doctor)          cmd_doctor ;;
    list)            cmd_list "${2:-}" ;;
    reload)          cmd_reload ;;
    starship)        cmd_starship "${2:-status}" ;;
    help|--help|-h)  usage ;;
    *)
        echo -e "${R}Unknown command: $1${NC}"
        echo ""
        usage
        exit 1
        ;;
esac
